MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=global_market

# Optional fallback/extra providers
TRADING_ECONOMICS_API_KEY=
TRADING_ECONOMICS_API_SECRET=

# Crawler runtime
REQUEST_TIMEOUT_MS=15000
USER_AGENT=veriq-markets-crawler/1.0
# Positive integer = max stocks; `all`, `0`, `-1`, `full`, or `unlimited` = entire scanner universe (slow; use TRADINGVIEW_SYMBOL_PAGE_ENRICH=0)
STOCK_DISCOVERY_LIMIT=all
# Comma-separated scanner markets, or `all`/`global`/`world` for all equity regions (~40k+). Default: america (~8k US).
TRADINGVIEW_MARKETS=all
# Per-stock console log when saving to Mongo (slower on huge crawls). Set 0 for bulk write only.
CRAWL_STOCK_PROGRESS=1
# After scanner list is saved: 1 = second phase fetches symbol pages (CEO, description, …). 0 = skip. Alias: STOCK_DETAIL_CRAWL.
TRADINGVIEW_SYMBOL_PAGE_ENRICH=1
# Override detail phase only (if set). Same truthy/falsy rules as above.
# STOCK_DETAIL_CRAWL=1
# Flush scanner rows to Mongo every N rows (list phase only).
STOCK_PERSIST_BATCH_SIZE=1000
# BulkWrite updates per batch in detail phase.
STOCK_DETAIL_BATCH_SIZE=1000
# Set to 1 to re-fetch symbol pages for all rows that have tradingviewSymbolSlug (ignores detail_enriched_at).
# STOCK_DETAIL_FORCE=0
# Để trống / `all` / `0` = lấy hết coin; số nguyên dương = tối đa N dòng.
CRYPTO_DISCOVERY_LIMIT=all
COMMODITY_DISCOVERY_LIMIT=all
VIETNAM_GOLD_DISCOVERY_LIMIT=10
